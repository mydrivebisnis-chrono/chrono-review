# ============================================================
# .env.example — Backend Environment Variables
# Salin file ini menjadi .env dan isi nilai yang sesuai.
# JANGAN commit .env ke repo.
# ============================================================

# Port server (default 8080 untuk Cloud Run)
PORT=8080

# Google Routes API Key
# Enable: Routes API di GCP Console
ROUTES_API_KEY=YOUR_GOOGLE_ROUTES_API_KEY_HERE

# Google Text-to-Speech Service Account Key (base64 encoded JSON)
# Format: base64(content of service-account.json)
# Enable: Cloud Text-to-Speech API + Chirp 3 HD
TTS_SA_KEY=BASE64_ENCODED_SERVICE_ACCOUNT_JSON_HERE

# Google Vertex AI / Gemini Service Account Key (base64 encoded JSON)
# Untuk Gemini Live 2.5 (gemini-2.0-flash-live-001)
GCP_VERTEX_SA_KEY=BASE64_ENCODED_VERTEX_SA_KEY_HERE

# Gemini API Key (alternatif dari Vertex SA Key)
# Ambil dari: aistudio.google.com/apikey
GEMINI_25_LIVE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Supabase JWT Secret
# Ambil dari: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_AUTH_JWT=YOUR_SUPABASE_JWT_SECRET_HERE

# Traffic refresh interval dalam milliseconds (default 120000 = 2 menit)
TRAFFIC_REFRESH_MS=120000
