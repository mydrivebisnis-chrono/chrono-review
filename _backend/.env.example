# ============================================================
# .env.example — Backend Environment Variables
# Salin file ini menjadi .env dan isi nilai yang sesuai.
# JANGAN commit .env ke repo — sudah di-block oleh .gitignore
# ============================================================

# Node environment: 'development' atau 'production'
NODE_ENV=development

# Port server (default 8080 untuk Cloud Run)
PORT=8080

# ── WebSocket Auth [AUTH-A] ────────────────────────────────────────────────
# Shared secret untuk autentikasi WebSocket (Opsi A — jangka pendek)
# Nilai = kSupabaseAnonKey dari Flutter (anon public key Supabase)
# Set di Cloud Run env vars — tidak perlu rebuild APK
WS_SHARED_SECRET=YOUR_SUPABASE_ANON_KEY_HERE

# ── Google APIs ────────────────────────────────────────────────────────────
ROUTES_API_KEY=YOUR_GOOGLE_ROUTES_API_KEY_HERE
TTS_SA_KEY=BASE64_ENCODED_SERVICE_ACCOUNT_JSON_HERE
GCP_VERTEX_SA_KEY=BASE64_ENCODED_VERTEX_SA_KEY_HERE
GEMINI_25_LIVE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Supabase (dipakai Opsi B — JWT user auth) ──────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY_HERE
SUPABASE_AUTH_JWT=YOUR_SUPABASE_JWT_SECRET_HERE

# ── Misc ───────────────────────────────────────────────────────────────────
TRAFFIC_REFRESH_MS=120000
